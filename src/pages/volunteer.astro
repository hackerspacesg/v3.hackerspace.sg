---
import { Icon } from 'astro-icon/components';
import { Button } from '@/components/ui/button';
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Volunteer"
  description="Volunteer with HackerspaceSG to get free access and help the community!">
  <div class="min-h-screen font-sans text-gray-800">
    <section class="px-4 py-8">
      <div class="container mx-auto text-center">
        <h1 class="mb-6 text-4xl font-bold text-red-600 md:text-6xl">
          Hack for Good
        </h1>
        <p class="mx-auto mb-8 max-w-3xl text-xl md:text-2xl">
          Join our volunteer program and get unlimited access to HackerspaceSG
          while making a difference in the tech community.
        </p>
      </div>
    </section>

    <section class="bg-white px-4 py-20">
      <div class="container mx-auto">
        <h2 class="mb-8 text-center text-3xl font-bold text-red-600">
          Volunteer Program
        </h2>
        <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
          <div class="rounded-lg bg-red-50 p-6 shadow-md">
            <h3
              class="mb-4 flex items-center text-2xl font-semibold text-red-600">
              <Icon name="fa:clock-o" class="mr-2 h-6 w-6" />
              Time Commitment
            </h3>
            <p class="mb-4">
              Volunteer for 16 hours a week and enjoy unlimited use of the space
              (equivalent to $256/month).
            </p>
          </div>
          <div class="rounded-lg bg-red-50 p-6 shadow-md">
            <h3
              class="mb-4 flex items-center text-2xl font-semibold text-red-600">
              <Icon name="fa:wrench" class="mr-2 h-6 w-6" />
              Responsibilities
            </h3>
            <p class="mb-4">
              Help maintain the space, assist with events, contribute to
              projects, and support the HackerspaceSG community.
            </p>
          </div>
          <div class="rounded-lg bg-red-50 p-6 shadow-md">
            <h3
              class="mb-4 flex items-center text-2xl font-semibold text-red-600">
              <Icon name="fa:users" class="mr-2 h-6 w-6" />
              Community Impact
            </h3>
            <p class="mb-4">
              Make a real difference in Singapore's tech scene while developing
              your skills and network.
            </p>
          </div>
          <div class="rounded-lg bg-red-50 p-6 shadow-md">
            <h3
              class="mb-4 flex items-center text-2xl font-semibold text-red-600">
              <Icon name="fa:bolt" class="mr-2 h-6 w-6" />
              Benefits
            </h3>
            <p class="mb-4">
              Gain unlimited access to the space, tools, and resources.
              Participate in exclusive events and workshops.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* How to Apply */}
    <section class="bg-red-50 px-4 py-20">
      <div class="container mx-auto">
        <h2 class="mb-8 text-center text-3xl font-bold text-red-600">
          How to Apply
        </h2>
        <div class="mx-auto max-w-3xl space-y-6">
          <div class="rounded-lg bg-white p-6 shadow-md">
            <p class="flex items-center text-xl">
              <Icon name="fa:chevron-right" class="mr-2 h-6 w-6 text-red-500" />
              Fill out the volunteer application form with your details and areas
              of interest.
            </p>
          </div>
          <div class="rounded-lg bg-white p-6 shadow-md">
            <p class="flex items-center text-xl">
              <Icon name="fa:chevron-right" class="mr-2 h-6 w-6 text-red-500" />
              Attend a brief interview with our volunteer coordinator to discuss
              your skills and availability.
            </p>
          </div>
          <div class="rounded-lg bg-white p-6 shadow-md">
            <p class="flex items-center text-xl">
              <Icon name="fa:chevron-right" class="mr-2 h-6 w-6 text-red-500" />
              Complete a short onboarding process to familiarize yourself with our
              space and procedures.
            </p>
          </div>
          <div class="rounded-lg bg-white p-6 shadow-md">
            <p class="flex items-center text-xl">
              <Icon name="fa:chevron-right" class="mr-2 h-6 w-6 text-red-500" />
              Start your volunteer journey and become an integral part of the HackerspaceSG
              community!
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Apply Now Section */}
    <section class="bg-white px-4 py-20">
      <div class="container mx-auto text-center">
        <h2 class="mb-8 text-3xl font-bold text-red-600">
          Ready to Hack for Good?
        </h2>
        <p class="mx-auto mb-8 max-w-2xl text-xl">
          Join our volunteer program today and help shape the future of
          technology in Singapore while enjoying unlimited access to
          HackerspaceSG.
        </p>
        <Button
          className="rounded-full bg-red-600 px-8 py-3 text-lg font-semibold text-white transition-colors hover:bg-red-700">
          Apply Now
        </Button>
      </div>
    </section>
  </div>
</Layout>
