---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const plans = [
  {
    name: 'Community',
    price: '$128/month',
    description: "Let's start here!",
    features: [true, true, true, true, false],
  },
  {
    name: 'Co-working',
    price: '$256/month',
    description: 'For anyone using the space 4–5 days/week.',
    features: [true, true, true, true, false],
  },
  {
    name: 'Dedicated',
    price: '$512/month',
    description: 'If you want to leave your crap on a desk.',
    features: [true, true, true, true, true],
  },
];

const features = [
  'Access to common areas',
  'Wi-Fi and printing',
  '24/7 access',
  'Storage',
  'Dedicated workspace',
];
---

<Layout title="Membership">
  <section class="w-full bg-white py-12 dark:bg-gray-800 md:py-24 lg:py-32">
    <div class="container mx-auto px-4 md:px-6">
      <h1
        class="mb-8 text-center text-3xl font-bold tracking-tighter text-red-600 dark:text-red-400 sm:text-5xl">
        Membership Options
      </h1>
      <p
        class="mx-auto mb-12 max-w-2xl text-center text-xl text-gray-600 dark:text-gray-300">
        Join our vibrant community of makers, hackers, and innovators. Choose
        the membership plan that suits your needs and start creating today!
      </p>
      <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-3">
        {
          plans.slice(0, 3).map((plan) => (
            <div class="rounded-lg bg-gray-50 p-6 shadow-md dark:bg-gray-700">
              <h3 class="mb-2 text-2xl font-bold text-red-600 dark:text-red-400">
                {plan.name}
              </h3>
              <p class="mb-4 text-3xl font-bold">{plan.price}</p>
              <p class="mb-6 text-gray-600 dark:text-gray-300">
                {plan.description}
              </p>
              <button class="w-full rounded bg-red-600 px-4 py-2 font-semibold text-white hover:bg-red-700 dark:bg-red-700 dark:hover:bg-red-800">
                <a href="https://docs.hackerspace.sg/handbook/membership">Choose {plan.name}</a>
              </button>
            </div>
          ))
        }
      </div>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-gray-700 dark:text-gray-300">
          <thead>
            <tr class="bg-gray-200 dark:bg-gray-700">
              <th class="p-4 text-left">Features</th>
              {
                plans.map((plan) => (
                  <th class="p-4 text-center">{plan.name}</th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              features.map((feature, featureIndex) => (
                <tr class="border-b dark:border-gray-700">
                  <td class="p-4">{feature}</td>
                  {plans.map((plan) => (
                    <td class="p-4 text-center">
                      {plan.features[featureIndex] ? (
                        <Icon
                          name="lucide:check"
                          class="inline-block text-green-500"
                        />
                      ) : (
                        <Icon
                          name="lucide:x"
                          class="inline-block text-red-500"
                        />
                      )}
                    </td>
                  ))}
                </tr>
              ))
            }
            <tr>
              <td class="p-4 font-bold">Price</td>
              {
                plans.map((plan) => (
                  <td class="p-4 text-center font-bold">{plan.price}</td>
                ))
              }
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</Layout>
