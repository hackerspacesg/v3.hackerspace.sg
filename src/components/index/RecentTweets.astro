---
import { Icon } from 'astro-icon/components';

// Mock data for tweets
const tweets = [
  {
    id: 1,
    text: 'Join us this weekend for our AI workshop! #HackerspaceSG #AIWorkshop',
    date: '2023-07-13',
  },
  {
    id: 2,
    text: 'Exciting projects coming out of our latest hackathon! Check them out: [link]',
    date: '2023-07-10',
  },
  {
    id: 3,
    text: "New equipment alert! We've just added 3D printers to our makerspace. Come and create! #3DPrinting",
    date: '2023-07-08',
  },
];
---

<div class="rounded-lg bg-white p-6 shadow-md dark:bg-gray-800">
  <h3 class="mb-4 flex items-center text-xl font-semibold dark:text-white">
    <Icon
      name="lucide:twitter"
      class="mr-2 h-6 w-6 text-red-600 dark:text-red-400"
    />
    Recent Tweets
  </h3>
  <ul class="space-y-4">
    {
      tweets.map((tweet) => (
        <li
          key={tweet.id}
          class="border-b border-gray-200 pb-4 last:border-b-0 last:pb-0 dark:border-gray-700">
          <p class="text-sm dark:text-gray-300">{tweet.text}</p>
          <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
            {new Date(tweet.date).toLocaleDateString('en-US', {
              month: 'long',
              day: 'numeric',
              year: 'numeric',
            })}
          </p>
        </li>
      ))
    }
  </ul>
</div>
